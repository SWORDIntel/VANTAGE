#!/usr/bin/env bash
# VANTAGE - External Tools Integration Module
# Version: 1.0.0
# Description: Plugin management and external tool integration system with MCP support
# Dependencies: logging config_cache shell_security
# Maintainer: VANTAGE Team

# Module metadata
VANTAGE_MODULE_DESCRIPTION="External tool integration and plugin management system"
VANTAGE_MODULE_VERSION="1.0.0"
VANTAGE_MODULE_DEPENDENCIES="logging config_cache shell_security"

# Prevent double loading
[[ -n "${_VANTAGE_EXTERNAL_TOOLS_LOADED}" ]] && return 0
export _VANTAGE_EXTERNAL_TOOLS_LOADED=1

# External tools configuration
VANTAGE_TOOLS_DIR="${VANTAGE_TOOLS_DIR:-$HOME/.vantage/tools}"
VANTAGE_TOOLS_REGISTRY="${VANTAGE_TOOLS_REGISTRY:-$VANTAGE_TOOLS_DIR/registry.json}"
VANTAGE_TOOLS_SANDBOX_DIR="${VANTAGE_TOOLS_SANDBOX_DIR:-$VANTAGE_TOOLS_DIR/sandbox}"
VANTAGE_TOOLS_PLUGINS_DIR="${VANTAGE_TOOLS_PLUGINS_DIR:-$VANTAGE_TOOLS_DIR/plugins}"

# MCP (Model Context Protocol) configuration
VANTAGE_MCP_ENABLED="${VANTAGE_MCP_ENABLED:-1}"
VANTAGE_MCP_SOCKET="${VANTAGE_MCP_SOCKET:-$VANTAGE_TOOLS_DIR/mcp.sock}"
VANTAGE_MCP_TIMEOUT="${VANTAGE_MCP_TIMEOUT:-30}"

# Security settings
VANTAGE_TOOLS_SANDBOX_ENABLED="${VANTAGE_TOOLS_SANDBOX_ENABLED:-1}"
VANTAGE_TOOLS_VERIFICATION="${VANTAGE_TOOLS_VERIFICATION:-1}"
VANTAGE_TOOLS_ALLOWED_COMMANDS="${VANTAGE_TOOLS_ALLOWED_COMMANDS:-git,docker,kubectl,terraform,ansible}"

# Create necessary directories
mkdir -p "$VANTAGE_TOOLS_DIR" "$VANTAGE_TOOLS_SANDBOX_DIR" "$VANTAGE_TOOLS_PLUGINS_DIR"

# Initialize registry if it doesn't exist
if [[ ! -f "$VANTAGE_TOOLS_REGISTRY" ]]; then
    echo '{"tools": {}, "plugins": {}, "version": "1.0.0"}' > "$VANTAGE_TOOLS_REGISTRY"
fi

# Tool discovery function
# Usage: vantage_tool_discover <path> [type]
vantage_tool_discover() {
    local search_path="${1:-$PATH}"
    local tool_type="${2:-all}"
    local discovered_tools=()
    
    vantage_log_info "external_tools" "Discovering tools in: $search_path"
    
    # Split PATH and search for executable tools
    IFS=':' read -ra PATHS <<< "$search_path"
    for path in "${PATHS[@]}"; do
        [[ ! -d "$path" ]] && continue
        
        # Search for known tool patterns
        for tool in $VANTAGE_TOOLS_ALLOWED_COMMANDS; do
            if [[ -x "$path/$tool" ]]; then
                local tool_info=$(vantage_tool_inspect "$path/$tool")
                if [[ -n "$tool_info" ]]; then
                    discovered_tools+=("$tool_info")
                fi
            fi
        done
    done
    
    # Return discovered tools as JSON array
    printf '{"discovered": [%s]}' "$(IFS=,; echo "${discovered_tools[*]}")"
}

# Tool inspection function
# Usage: vantage_tool_inspect <tool_path>
vantage_tool_inspect() {
    local tool_path="$1"
    local tool_name=$(basename "$tool_path")
    local tool_version=""
    local tool_type="binary"
    
    # Try to get version information
    if [[ -x "$tool_path" ]]; then
        # Common version flags
        for flag in --version -v -V version; do
            if tool_version=$("$tool_path" $flag 2>&1 | head -n1); then
                break
            fi
        done
    fi
    
    # Detect tool type
    if [[ "$tool_name" =~ ^(git|gh|hub)$ ]]; then
        tool_type="vcs"
    elif [[ "$tool_name" =~ ^(docker|podman|kubectl|k9s)$ ]]; then
        tool_type="container"
    elif [[ "$tool_name" =~ ^(terraform|ansible|puppet|chef)$ ]]; then
        tool_type="infrastructure"
    elif [[ "$tool_name" =~ ^(npm|yarn|pip|cargo|go)$ ]]; then
        tool_type="package_manager"
    fi
    
    # Return tool information as JSON
    cat <<EOF
{
    "name": "$tool_name",
    "path": "$tool_path",
    "type": "$tool_type",
    "version": "$(echo "$tool_version" | jq -Rs .)",
    "discovered": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
}

# Tool registration function
# Usage: vantage_tool_register <name> <path> [metadata]
vantage_tool_register() {
    local tool_name="$1"
    local tool_path="$2"
    local metadata="${3:-'{}'}"
    
    [[ -z "$tool_name" || -z "$tool_path" ]] && {
        vantage_log_error "external_tools" "Tool name and path required for registration"
        return 1
    }
    
    # Verify tool exists and is executable
    if [[ ! -x "$tool_path" ]]; then
        vantage_log_error "external_tools" "Tool not found or not executable: $tool_path"
        return 1
    fi
    
    # Security verification if enabled
    if [[ "$VANTAGE_TOOLS_VERIFICATION" == "1" ]]; then
        if ! vantage_tool_verify "$tool_path"; then
            vantage_log_error "external_tools" "Tool verification failed: $tool_name"
            return 1
        fi
    fi
    
    # Update registry
    local registry_update=$(jq --arg name "$tool_name" \
                              --arg path "$tool_path" \
                              --argjson meta "$metadata" \
                              '.tools[$name] = {
                                  "path": $path,
                                  "metadata": $meta,
                                  "registered": now | strftime("%Y-%m-%dT%H:%M:%SZ"),
                                  "enabled": true
                              }' "$VANTAGE_TOOLS_REGISTRY")
    
    echo "$registry_update" > "$VANTAGE_TOOLS_REGISTRY"
    vantage_log_info "external_tools" "Registered tool: $tool_name"
    
    # Generate wrapper if sandboxing is enabled
    if [[ "$VANTAGE_TOOLS_SANDBOX_ENABLED" == "1" ]]; then
        vantage_tool_create_sandbox_wrapper "$tool_name" "$tool_path"
    fi
    
    return 0
}

# Tool verification function
# Usage: vantage_tool_verify <tool_path>
vantage_tool_verify() {
    local tool_path="$1"
    local tool_name=$(basename "$tool_path")
    
    # Check if tool is in allowed list
    local allowed=0
    for cmd in $(echo "$VANTAGE_TOOLS_ALLOWED_COMMANDS" | tr "," " "); do
        if [ "$cmd" = "$tool_name" ]; then
            allowed=1
            break
        fi
    done
    if [ $allowed -eq 0 ]; then
        vantage_log_warning "external_tools" "Tool not in allowed list: $tool_name"
        return 1
    fi
    
    # Check file permissions
    local file_perms=$(stat -c %a "$tool_path" 2>/dev/null || stat -f %p "$tool_path" 2>/dev/null)
    if [[ "$file_perms" =~ [2367]$ ]]; then
        vantage_log_warning "external_tools" "Suspicious permissions on tool: $tool_path"
        return 1
    fi
    
    # Additional security checks can be added here
    
    return 0
}

# Sandbox wrapper creation
# Usage: vantage_tool_create_sandbox_wrapper <name> <path>
vantage_tool_create_sandbox_wrapper() {
    local tool_name="$1"
    local tool_path="$2"
    local wrapper_path="$VANTAGE_TOOLS_SANDBOX_DIR/$tool_name"
    
    cat > "$wrapper_path" <<'EOF'
#!/usr/bin/env bash
# VANTAGE sandbox wrapper for: TOOL_NAME

# Sandbox configuration
TOOL_PATH="TOOL_PATH_PLACEHOLDER"
TOOL_NAME="TOOL_NAME_PLACEHOLDER"

# Load VANTAGE security functions
_vantage_root="${VANTAGE_ROOT:-$HOME/.vantage}"
_security_module_path=""
if [[ -f "$_vantage_root/bash_modules.d/shell_security.module" ]]; then
    _security_module_path="$_vantage_root/bash_modules.d/shell_security.module"
elif [[ -f "$HOME/bash_modules.d/shell_security.module" ]]; then
    _security_module_path="$HOME/bash_modules.d/shell_security.module"
fi
if [[ -n "$_security_module_path" ]]; then
    source "$_security_module_path"
fi

# Pre-execution checks
vantage_sandbox_pre_exec() {
    # Log execution attempt
    vantage_log_info "sandbox" "Executing sandboxed tool: $TOOL_NAME"
    
    # Check for suspicious arguments
    for arg in "$@"; do
        if [[ "$arg" =~ (rm|delete|destroy|drop|truncate) ]]; then
            vantage_log_warning "sandbox" "Potentially dangerous argument detected: $arg"
            read -p "Continue execution? [y/N] " -n 1 -r
            echo
            [[ ! $REPLY =~ ^[Yy]$ ]] && return 1
        fi
    done
    
    return 0
}

# Execute with sandboxing
if vantage_sandbox_pre_exec "$@"; then
    # Set resource limits if available
    if command -v ulimit >/dev/null 2>&1; then
        ulimit -t 300  # CPU time limit (5 minutes)
        ulimit -v 2097152  # Virtual memory limit (2GB)
    fi
    
    # Execute the actual tool
    exec "$TOOL_PATH" "$@"
else
    exit 1
fi
EOF
    
    # Replace placeholders
    sed -i "s|TOOL_PATH_PLACEHOLDER|$tool_path|g" "$wrapper_path"
    sed -i "s|TOOL_NAME_PLACEHOLDER|$tool_name|g" "$wrapper_path"
    
    chmod +x "$wrapper_path"
    vantage_log_info "external_tools" "Created sandbox wrapper: $wrapper_path"
}

# MCP (Model Context Protocol) integration
# Usage: vantage_mcp_init
vantage_mcp_init() {
    [[ "$VANTAGE_MCP_ENABLED" != "1" ]] && return 0
    
    vantage_log_info "external_tools" "Initializing MCP integration"
    
    # Create MCP socket directory
    local socket_dir=$(dirname "$VANTAGE_MCP_SOCKET")
    mkdir -p "$socket_dir"
    
    # Start MCP listener if not already running
    if [[ ! -S "$VANTAGE_MCP_SOCKET" ]]; then
        vantage_mcp_listener &
        local listener_pid=$!
        echo "$listener_pid" > "$VANTAGE_TOOLS_DIR/mcp.pid"
    fi
}

# MCP listener implementation
vantage_mcp_listener() {
    local socket="$VANTAGE_MCP_SOCKET"
    
    # Clean up old socket if exists
    [[ -S "$socket" ]] && rm -f "$socket"
    
    # Create named pipe for MCP communication
    mkfifo "$socket" 2>/dev/null || {
        vantage_log_error "external_tools" "Failed to create MCP socket"
        return 1
    }
    
    # Listen for MCP requests
    while true; do
        if read -r request < "$socket"; then
            # Parse MCP request
            local response=$(vantage_mcp_handle_request "$request")
            echo "$response" > "$socket.response"
        fi
        sleep 0.1
    done
}

# MCP request handler
# Usage: vantage_mcp_handle_request <request_json>
vantage_mcp_handle_request() {
    local request="$1"
    local method=$(echo "$request" | jq -r '.method // ""')
    local params=$(echo "$request" | jq -r '.params // {}')
    
    case "$method" in
        "tool.execute")
            local tool_name=$(echo "$params" | jq -r '.tool')
            local tool_args=$(echo "$params" | jq -r '.args[]')
            vantage_tool_execute "$tool_name" $tool_args
            ;;
        "tool.list")
            vantage_tool_list_json
            ;;
        "tool.info")
            local tool_name=$(echo "$params" | jq -r '.tool')
            vantage_tool_info "$tool_name"
            ;;
        *)
            echo '{"error": "Unknown method", "code": -32601}'
            ;;
    esac
}

# Tool execution with logging and sandboxing
# Usage: vantage_tool_execute <name> [args...]
vantage_tool_execute() {
    local tool_name="$1"
    shift
    
    # Get tool info from registry
    local tool_info=$(jq -r --arg name "$tool_name" '.tools[$name] // empty' "$VANTAGE_TOOLS_REGISTRY")
    
    if [[ -z "$tool_info" ]]; then
        vantage_log_error "external_tools" "Tool not registered: $tool_name"
        return 1
    fi
    
    local tool_path=$(echo "$tool_info" | jq -r '.path')
    local enabled=$(echo "$tool_info" | jq -r '.enabled')
    
    if [[ "$enabled" != "true" ]]; then
        vantage_log_error "external_tools" "Tool is disabled: $tool_name"
        return 1
    fi
    
    # Log execution
    vantage_log_info "external_tools" "Executing tool: $tool_name $*"
    
    # Execute through sandbox wrapper if enabled
    if [[ "$VANTAGE_TOOLS_SANDBOX_ENABLED" == "1" && -x "$VANTAGE_TOOLS_SANDBOX_DIR/$tool_name" ]]; then
        "$VANTAGE_TOOLS_SANDBOX_DIR/$tool_name" "$@"
    else
        "$tool_path" "$@"
    fi
}

# List registered tools
# Usage: vantage_tool_list [format]
vantage_tool_list() {
    local format="${1:-table}"
    
    case "$format" in
        json)
            vantage_tool_list_json
            ;;
        table|*)
            vantage_tool_list_table
            ;;
    esac
}

# List tools in JSON format
vantage_tool_list_json() {
    jq '.tools' "$VANTAGE_TOOLS_REGISTRY"
}

# List tools in table format
vantage_tool_list_table() {
    echo "Registered External Tools:"
    echo "========================="
    printf "%-20s %-10s %-10s %s\n" "NAME" "TYPE" "ENABLED" "PATH"
    echo "-------------------------------------------------------------------------"
    
    jq -r '.tools | to_entries[] | 
        "\(.key)|\(.value.metadata.type // "unknown")|\(.value.enabled)|\(.value.path)"' \
        "$VANTAGE_TOOLS_REGISTRY" | \
    while IFS='|' read -r name type enabled path; do
        printf "%-20s %-10s %-10s %s\n" "$name" "$type" "$enabled" "$path"
    done
}

# Get tool information
# Usage: vantage_tool_info <name>
vantage_tool_info() {
    local tool_name="$1"
    
    jq -r --arg name "$tool_name" '.tools[$name] // {"error": "Tool not found"}' "$VANTAGE_TOOLS_REGISTRY"
}

# Plugin loader
# Usage: vantage_plugin_load <plugin_name>
vantage_plugin_load() {
    local plugin_name="$1"
    local plugin_file="$VANTAGE_TOOLS_PLUGINS_DIR/${plugin_name}.plugin"
    
    if [[ ! -f "$plugin_file" ]]; then
        vantage_log_error "external_tools" "Plugin not found: $plugin_name"
        return 1
    fi
    
    # Source plugin with error handling
    if source "$plugin_file"; then
        vantage_log_info "external_tools" "Loaded plugin: $plugin_name"
        
        # Register plugin in registry
        jq --arg name "$plugin_name" \
           --arg file "$plugin_file" \
           '.plugins[$name] = {
               "file": $file,
               "loaded": now | strftime("%Y-%m-%dT%H:%M:%SZ"),
               "enabled": true
           }' "$VANTAGE_TOOLS_REGISTRY" > "$VANTAGE_TOOLS_REGISTRY.tmp" && \
        mv "$VANTAGE_TOOLS_REGISTRY.tmp" "$VANTAGE_TOOLS_REGISTRY"
    else
        vantage_log_error "external_tools" "Failed to load plugin: $plugin_name"
        return 1
    fi
}

# Tool alias creation
# Usage: vantage_tool_alias <alias_name> <tool_name> [default_args]
vantage_tool_alias() {
    local alias_name="$1"
    local tool_name="$2"
    shift 2
    local default_args="$*"
    
    # Create alias function
    eval "
    $alias_name() {
        vantage_tool_execute '$tool_name' $default_args \"\$@\"
    }
    export -f $alias_name
    "
    
    vantage_log_info "external_tools" "Created alias: $alias_name -> $tool_name $default_args"
}

# Initialize external tools on module load
vantage_external_tools_init() {
    # Initialize MCP if enabled
    [[ "$VANTAGE_MCP_ENABLED" == "1" ]] && vantage_mcp_init
    
    # Load registered plugins
    if [[ -f "$VANTAGE_TOOLS_REGISTRY" ]]; then
        local plugins=$(jq -r '.plugins | to_entries[] | select(.value.enabled == true) | .key' "$VANTAGE_TOOLS_REGISTRY" 2>/dev/null)
        for plugin in $plugins; do
            vantage_plugin_load "$plugin"
        done
    fi
    
    # Auto-discover common tools
    if [[ "${VANTAGE_TOOLS_AUTO_DISCOVER:-1}" == "1" ]]; then
        vantage_tool_discover "$PATH" >/dev/null 2>&1
    fi
    
    vantage_log_info "external_tools" "External tools module initialized"
}

# Export functions
export -f vantage_tool_discover
export -f vantage_tool_inspect
export -f vantage_tool_register
export -f vantage_tool_verify
export -f vantage_tool_create_sandbox_wrapper
export -f vantage_mcp_init
export -f vantage_mcp_listener
export -f vantage_mcp_handle_request
export -f vantage_tool_execute
export -f vantage_tool_list
export -f vantage_tool_list_json
export -f vantage_tool_list_table
export -f vantage_tool_info
export -f vantage_plugin_load
export -f vantage_tool_alias
export -f vantage_external_tools_init

# Initialize module
vantage_external_tools_init