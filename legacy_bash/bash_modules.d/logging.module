#!/usr/bin/env bash
# VANTAGE - Logging Module
# Version: 1.1.0
# Description: Provides centralized logging functionality for all VANTAGE modules
# Dependencies: config_loader (for centralized configuration)
# Maintainer: VANTAGE Team

# Prevent double loading
[[ -n "${_VANTAGE_LOGGING_LOADED}" ]] && return 0
export _VANTAGE_LOGGING_LOADED=1

# Log directory location
VANTAGE_LOG_DIR=~/.vantage/logs

# Define log levels
: "${VANTAGE_LOG_LEVEL_DEBUG:=0}"
: "${VANTAGE_LOG_LEVEL_INFO:=1}"
: "${VANTAGE_LOG_LEVEL_WARNING:=2}"
: "${VANTAGE_LOG_LEVEL_ERROR:=3}"
: "${VANTAGE_LOG_LEVEL_CRITICAL:=4}"
: "${VANTAGE_LOG_LEVEL:=1}"

# Use centralized config, or fall back to defaults if not available/loaded
if [[ -n "$VANTAGE_CONFIG_FILE" && -f "$VANTAGE_CONFIG_FILE" ]]; then
    # Config already loaded, use existing values (do nothing)
    :
else
    # Default values if config_loader wasn't loaded first
    : "${VANTAGE_LOG_RETENTION_DAYS:=30}"
    : "${VANTAGE_LOG_COLORS_ENABLED:=true}"
    : "${VANTAGE_LOG_ROTATION_SIZE:=1024}"  # 1MB
fi

# Main logging function with error handling to prevent terminal crashes
vantage_log() {
    # Support both current and legacy call signatures:
    #   vantage_log <numeric-level> <component> <message> [exit_code]
    #   vantage_log <text-level> <message>
    #   vantage_log <component> <message>
    #   vantage_log <message>
    local level component message exit_code
    case "${1:-}" in
        '' )
            level=${VANTAGE_LOG_LEVEL_INFO:-1}
            component="unknown"
            message=""
            exit_code=0
            ;;
        ''|*[!0-9]*)
            case "${1,,}" in
                debug)
                    level=${VANTAGE_LOG_LEVEL_DEBUG:-0}
                    component=${2:-"unknown"}
                    message=${3:-${2:-""}}
                    [[ $# -ge 3 ]] || component="unknown"
                    exit_code=${4:-0}
                    ;;
                info)
                    level=${VANTAGE_LOG_LEVEL_INFO:-1}
                    component=${2:-"unknown"}
                    message=${3:-${2:-""}}
                    [[ $# -ge 3 ]] || component="unknown"
                    exit_code=${4:-0}
                    ;;
                warning|warn)
                    level=${VANTAGE_LOG_LEVEL_WARNING:-2}
                    component=${2:-"unknown"}
                    message=${3:-${2:-""}}
                    [[ $# -ge 3 ]] || component="unknown"
                    exit_code=${4:-0}
                    ;;
                error)
                    level=${VANTAGE_LOG_LEVEL_ERROR:-3}
                    component=${2:-"unknown"}
                    message=${3:-${2:-""}}
                    [[ $# -ge 3 ]] || component="unknown"
                    exit_code=${4:-0}
                    ;;
                critical)
                    level=${VANTAGE_LOG_LEVEL_CRITICAL:-4}
                    component=${2:-"unknown"}
                    message=${3:-${2:-""}}
                    [[ $# -ge 3 ]] || component="unknown"
                    exit_code=${4:-0}
                    ;;
                *)
                    level=${VANTAGE_LOG_LEVEL_INFO:-1}
                    component=${2:-"unknown"}
                    message=${2:-$1}
                    [[ $# -ge 2 ]] || component="unknown"
                    exit_code=${3:-0}
                    ;;
            esac
            ;;
        *)
            level=${1:-${VANTAGE_LOG_LEVEL_INFO:-1}}
            component=${2:-"unknown"}
            message=${3:-""}
            exit_code=${4:-0}
            ;;
    esac
    
    # Early return if log level is below configured level
    # Example: If VANTAGE_LOG_LEVEL=2 (WARNING), DEBUG(0) and INFO(1) are skipped
    [[ "$level" =~ ^[0-9]+$ ]] || level=${VANTAGE_LOG_LEVEL_INFO:-1}
    [[ $level -lt ${VANTAGE_LOG_LEVEL:-1} ]] && return 0
    
    # Generate timestamp safely
    local timestamp
    timestamp=$(date +"%Y-%m-%d %H:%M:%S" 2>/dev/null) || timestamp="UNKNOWN_TIME"
    
    # Generate log_file path safely
    local date_suffix
    date_suffix=$(date +%Y%m%d 2>/dev/null) || date_suffix="unknown"
    local log_file="${VANTAGE_LOG_DIR:-$HOME/.vantage/logs}/${component}-${date_suffix}.log"
    
    # Ensure log directory exists with error handling
    mkdir -p "${VANTAGE_LOG_DIR:-$HOME/.vantage/logs}" 2>/dev/null || {
        # If we can't create the log directory, use a fallback approach
        if [[ -d "/tmp" ]]; then
            # Use /tmp as fallback
            log_file="/tmp/vantage-${component}-${date_suffix}.log"
        else
            # If we can't log anywhere, just return
            return $exit_code
        fi
    }
    
    # Convert level to text safely
    local level_text="UNKNOWN"
    case $level in
        $VANTAGE_LOG_LEVEL_DEBUG)
            level_text="DEBUG"
            ;;
        $VANTAGE_LOG_LEVEL_INFO)
            level_text="INFO"
            ;;
        $VANTAGE_LOG_LEVEL_WARNING)
            level_text="WARNING"
            ;;
        $VANTAGE_LOG_LEVEL_ERROR)
            level_text="ERROR"
            ;;
        $VANTAGE_LOG_LEVEL_CRITICAL)
            level_text="CRITICAL"
            ;;
    esac
    
    # Format: [TIMESTAMP] [LEVEL] [COMPONENT] Message
    local log_entry="[$timestamp] [$level_text] [$component] $message"
    
    # Write to log file with error handling
    echo "$log_entry" >> "$log_file" 2>/dev/null || true
    
    # For errors and critical messages, also output to stderr if we're in a terminal
    if [[ $level -ge ${VANTAGE_LOG_LEVEL_ERROR:-3} ]]; then
        # Only output to terminal if it exists
        if [[ -t 2 ]]; then
            if [[ "${VANTAGE_LOG_COLORS_ENABLED:-false}" == "true" ]]; then
                # Color coding for terminal output with error handling
                local color="\033[0m" # Default
                if [[ $level -eq ${VANTAGE_LOG_LEVEL_ERROR:-3} ]]; then
                    color="\033[1;31m" # Red
                elif [[ $level -eq ${VANTAGE_LOG_LEVEL_CRITICAL:-4} ]]; then
                    color="\033[1;35m" # Purple for critical
                fi
                # Use printf instead of echo -e for better portability
                printf "%b%s%b\n" "$color" "$log_entry" "\033[0m" >&2 2>/dev/null || echo "$log_entry" >&2
            else
                echo "$log_entry" >&2 2>/dev/null || true
            fi
        fi
    fi
    
    # Check log file size and rotate if needed - with error handling
    if [[ -f "$log_file" ]]; then
        # Get file size, defaulting to 0 if stat fails
        local file_size=0
        if command -v stat &>/dev/null; then
            file_size=$(stat -c %s "$log_file" 2>/dev/null || echo "0")
            
            # Only proceed if we got a valid size and rotation is configured
            if [[ $file_size =~ ^[0-9]+$ && ${VANTAGE_LOG_ROTATION_SIZE:-1024} -gt 0 ]]; then
                # Convert to KB for comparison
                file_size=$(( file_size / 1024 ))
                if [[ $file_size -gt ${VANTAGE_LOG_ROTATION_SIZE:-1024} ]]; then
                    # Rotate log file with error handling
                    mv "$log_file" "${log_file}.1" 2>/dev/null || true
                fi
            fi
        fi
    fi
    
    return $exit_code
}

# Specific logging functions for each level
vantage_log_debug() {
    local component=$1
    local message=$2
    vantage_log $VANTAGE_LOG_LEVEL_DEBUG "$component" "$message"
}

vantage_log_info() {
    local component=$1
    local message=$2
    vantage_log $VANTAGE_LOG_LEVEL_INFO "$component" "$message"
}

vantage_log_warning() {
    local component=$1
    local message=$2
    vantage_log $VANTAGE_LOG_LEVEL_WARNING "$component" "$message"
}

vantage_log_error() {
    local component=$1
    local message=$2
    vantage_log $VANTAGE_LOG_LEVEL_ERROR "$component" "$message"
}

vantage_log_critical() {
    local component=$1
    local message=$2
    vantage_log $VANTAGE_LOG_LEVEL_CRITICAL "$component" "$message"
}

# Function to clean up old log files
vantage_log_cleanup() {
    # Allow override of default retention period
    local retention_days="${1:-$VANTAGE_LOG_RETENTION_DAYS}"
    
    # Ensure log directory exists
    if [[ ! -d "$VANTAGE_LOG_DIR" ]]; then
        mkdir -p "$VANTAGE_LOG_DIR"
    fi
    
    # Remove logs older than retention_days
    find "$VANTAGE_LOG_DIR" -type f -name "*.log*" -mtime "+${retention_days}" -delete 2>/dev/null
    
    # Log the cleanup action
    vantage_log_info "logging" "Cleaned up log files older than $retention_days days"
}

# Function to display recent logs
# Usage: vantage_show_logs [component] [lines=20]
vantage_show_logs() {
    local component="${1:-all}"
    local lines="${2:-20}"
    
    local log_pattern="$VANTAGE_LOG_DIR/${component}-*.log"
    
    if [[ ! -d "$VANTAGE_LOG_DIR" ]]; then
        echo "Log directory not found. No logs to display."
        return 0
    fi
    
    if [[ "$component" == "all" ]]; then
        log_pattern="$VANTAGE_LOG_DIR/*.log"
    fi
    
    if ! ls $log_pattern 1>/dev/null 2>&1; then
        echo "No logs found for component: $component"
        return 0
    fi
    
    # Display the most recent logs
    echo "=== Recent logs for $component (last $lines lines) ==="
    
    # Use colors if enabled and we're in a terminal
    if [[ "$VANTAGE_LOG_COLORS_ENABLED" == "true" && -t 1 ]]; then
        # More sophisticated colorization
        ls -t $log_pattern | head -1 | xargs tail -n $lines | 
        sed -E 's/\[(DEBUG)\]/[\\033[1;34m\1\\033[0m]/g' | 
        sed -E 's/\[(INFO)\]/[\\033[1;32m\1\\033[0m]/g' | 
        sed -E 's/\[(WARNING)\]/[\\033[1;33m\1\\033[0m]/g' | 
        sed -E 's/\[(ERROR)\]/[\\033[1;31m\1\\033[0m]/g' | 
        sed -E 's/\[(CRITICAL)\]/[\\033[1;35m\1\\033[0m]/g' |
        sed 's/\\033/\x1B/g'
    else
        ls -t $log_pattern | head -1 | xargs tail -n $lines
    fi
    
    echo "=== End of logs ==="
}

# Usage: vantage_log_exception <component> <message> [exit_code]
vantage_log_exception() {
    local component=$1
    local message=$2
    local exit_code=${3:-1}
    
    # Get stack trace
    local i=0
    local stack_trace=""
    while caller $i > /dev/null; do
        local j=$i
        ((i++))
        caller $j >> /dev/null || break
        local frame=$(caller $j)
        stack_trace="$stack_trace\n    at ${frame}"
    done
    
    # Format the exception message
    local exception_msg="Exception: $message$stack_trace"
    
    # Log the exception
    vantage_log_error "$component" "$exception_msg"
    
    return $exit_code
}

# Initialize the logging system
vantage_init_logging() {
    # Create log directory if it doesn't exist
    mkdir -p "$VANTAGE_LOG_DIR"
    
    # Schedule log cleanup in background to avoid slowing down shell startup
    (vantage_log_cleanup >/dev/null 2>&1 &)
    
    # Log that the logging system is initialized
    vantage_log_info "logging" "Logging system initialized (level=${VANTAGE_LOG_LEVEL})"
    
    return 0
}

# Export functions
export -f vantage_log
export -f vantage_log_debug
export -f vantage_log_info
export -f vantage_log_warning
export -f vantage_log_error
export -f vantage_log_critical
export -f vantage_log_cleanup
export -f vantage_show_logs
export -f vantage_log_exception

# Initialize logging system
vantage_init_logging 
