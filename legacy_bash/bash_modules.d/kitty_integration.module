#!/usr/bin/env bash
# VANTAGE Kitty Integration Module
# Provides kitty-specific optimizations and detection functions

# Prevent multiple loading
[[ -n "${_VANTAGE_KITTY_INTEGRATION_LOADED}" ]] && return 0
export _VANTAGE_KITTY_INTEGRATION_LOADED=1

# Detect if running in kitty terminal
vantage_is_kitty() {
    [[ -n "${KITTY_WINDOW_ID:-}" ]] || \
    [[ "${TERM:-}" == "xterm-kitty" ]] || \
    [[ "${TERM_PROGRAM:-}" == "kitty" ]] || \
    [[ "${VANTAGE_KITTY_PRIMARY_CLI:-0}" == "1" ]]
}

# Detect if kitty is available (even if not currently running in it)
vantage_kitty_available() {
    command -v kitty >/dev/null 2>&1 && \
    [[ -n "${WAYLAND_DISPLAY:-}" || -n "${DISPLAY:-}" ]]
}

# Get kitty window ID if available
vantage_kitty_window_id() {
    echo "${KITTY_WINDOW_ID:-}"
}

# Send OSC commands to kitty (for advanced features)
vantage_kitty_osc() {
    if vantage_is_kitty && [[ -n "${KITTY_WINDOW_ID:-}" ]]; then
        printf "\033]%s\033\\" "$1" >&2
    fi
}

# Set kitty window title
vantage_kitty_set_title() {
    local title="${1:-VANTAGE}"
    vantage_kitty_osc "2;${title}"
}

# Set kitty tab title
vantage_kitty_set_tab_title() {
    local title="${1:-VANTAGE}"
    vantage_kitty_osc "30;${title}"
}

# Enable kitty shell integration features
vantage_kitty_enable_features() {
    if vantage_is_kitty; then
        # Enable kitty's shell integration
        if [[ -n "${KITTY_SHELL_INTEGRATION:-}" ]]; then
            export KITTY_SHELL_INTEGRATION="enabled"
        fi
        
        # Set GPU acceleration flag
        export VANTAGE_KITTY_GPU_ACCEL=1
        
        # Optimize colors for kitty
        export VANTAGE_TERMINAL_COLORS=256
        
        return 0
    fi
    return 1
}

# Initialize kitty integration
if vantage_is_kitty; then
    vantage_kitty_enable_features
    
    # Set initial window title
    vantage_kitty_set_title "VANTAGE - Kitty Primary CLI"
fi
