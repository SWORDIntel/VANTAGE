#!/usr/bin/env bash
# VANTAGE Module: Parallel Module Loader
# Implements parallel loading with dependency graph analysis and caching

# Prevent multiple loading
[[ -n "${_VANTAGE_PARALLEL_LOADER_LOADED:-}" ]] && return 0
export _VANTAGE_PARALLEL_LOADER_LOADED=1

VANTAGE_MODULE_DESCRIPTION="Parallel module loading with dependency resolution and caching"
VANTAGE_MODULE_VERSION="1.0.0"
VANTAGE_MODULE_DEPENDENCIES="logging config_cache"

# Cache directory for module metadata
VANTAGE_MODULE_CACHE_DIR="${VANTAGE_MODULE_CACHE_DIR:-$HOME/.cache/vantage/modules}"
mkdir -p "$VANTAGE_MODULE_CACHE_DIR"

# Timing data storage
declare -gA VANTAGE_MODULE_LOAD_TIMES
declare -gA VANTAGE_MODULE_CACHE_HITS

# Dependency graph storage
declare -gA VANTAGE_MODULE_DEPS_GRAPH
declare -gA VANTAGE_MODULE_REVERSE_DEPS

# Module metadata cache
declare -gA VANTAGE_MODULE_METADATA_CACHE

# Parallel loading configuration
VANTAGE_PARALLEL_MAX_JOBS="${VANTAGE_PARALLEL_MAX_JOBS:-4}"
VANTAGE_PARALLEL_TIMEOUT="${VANTAGE_PARALLEL_TIMEOUT:-30}"

# Function to calculate file hash for cache validation
_calculate_file_hash() {
    local file="$1"
    if command -v sha256sum &>/dev/null; then
        sha256sum "$file" 2>/dev/null | cut -d' ' -f1
    elif command -v shasum &>/dev/null; then
        shasum -a 256 "$file" 2>/dev/null | cut -d' ' -f1
    else
        # Fallback to modification time
        stat -c %Y "$file" 2>/dev/null || stat -f %m "$file" 2>/dev/null || echo "0"
    fi
}

# Function to load module metadata from cache or file
_load_module_metadata() {
    local module_name="$1"
    local module_file="$2"
    local cache_file="$VANTAGE_MODULE_CACHE_DIR/${module_name}.meta"
    local start_time=$(date +%s%N 2>/dev/null || date +%s)
    
    # Check if module file exists
    if [[ ! -f "$module_file" ]]; then
        return 1
    fi
    
    # Calculate file hash
    local file_hash=$(_calculate_file_hash "$module_file")
    
    # Check cache validity
    if [[ -f "$cache_file" ]]; then
        local cached_hash=$(head -n1 "$cache_file" 2>/dev/null)
        if [[ "$cached_hash" == "$file_hash" ]]; then
            # Cache hit - load from cache
            VANTAGE_MODULE_CACHE_HITS["$module_name"]=1
            local metadata=$(tail -n +2 "$cache_file")
            metadata="$(printf '%s\n' "$metadata" | sed "s|^FILE:.*$|FILE:$module_file|")"
            VANTAGE_MODULE_METADATA_CACHE["$module_name"]="$metadata"
            
            # Parse dependencies from cache
            local deps=$(echo "$metadata" | grep "^DEPS:" | cut -d':' -f2-)
            if [[ -n "$deps" ]]; then
                VANTAGE_MODULE_DEPS_GRAPH["$module_name"]="$deps"
                for dep in $deps; do
                    local current_reverse="${VANTAGE_MODULE_REVERSE_DEPS[$dep]:-}"
                    if [[ -n "$current_reverse" ]]; then
                        VANTAGE_MODULE_REVERSE_DEPS["$dep"]="$current_reverse $module_name"
                    else
                        VANTAGE_MODULE_REVERSE_DEPS["$dep"]="$module_name"
                    fi
                done
            fi
            
            local end_time=$(date +%s%N 2>/dev/null || date +%s)
            local duration=$((($end_time - $start_time) / 1000000)) # Convert to milliseconds
            [[ "${VANTAGE_DEBUG_MODULES:-0}" == "1" ]] && echo "DEBUG: Metadata cache hit for $module_name (${duration}ms)" >&2
            
            return 0
        fi
    fi
    
    # Cache miss - parse module file
    local description=""
    local version=""
    local dependencies=""
    
    # Extract metadata with single file read
    while IFS= read -r line; do
        case "$line" in
            *"VANTAGE_MODULE_DESCRIPTION="*)
                description="${line#*VANTAGE_MODULE_DESCRIPTION=}"
                description="${description//\"/}"
                ;;
            *"VANTAGE_MODULE_VERSION="*)
                version="${line#*VANTAGE_MODULE_VERSION=}"
                version="${version//\"/}"
                ;;
            *"VANTAGE_MODULE_DEPENDENCIES="*)
                dependencies="${line#*VANTAGE_MODULE_DEPENDENCIES=}"
                dependencies="${dependencies//\"/}"
                ;;
        esac
        
        # Stop parsing after finding all metadata
        if [[ -n "$description" && -n "$version" && -n "$dependencies" ]]; then
            break
        fi
    done < "$module_file"
    
    # Build metadata
    local metadata="DESC:$description
VER:$version
DEPS:$dependencies
FILE:$module_file"
    
    # Store in memory cache
    VANTAGE_MODULE_METADATA_CACHE["$module_name"]="$metadata"
    
    # Store dependencies in graph
    if [[ -n "$dependencies" ]]; then
        VANTAGE_MODULE_DEPS_GRAPH["$module_name"]="$dependencies"
        
        # Build reverse dependency graph
        for dep in $dependencies; do
            local current_reverse="${VANTAGE_MODULE_REVERSE_DEPS[$dep]:-}"
            if [[ -n "$current_reverse" ]]; then
                VANTAGE_MODULE_REVERSE_DEPS["$dep"]="$current_reverse $module_name"
            else
                VANTAGE_MODULE_REVERSE_DEPS["$dep"]="$module_name"
            fi
        done
    fi
    
    # Write to cache file
    {
        echo "$file_hash"
        echo "$metadata"
    } > "$cache_file" 2>/dev/null
    
    local end_time=$(date +%s%N 2>/dev/null || date +%s)
    local duration=$((($end_time - $start_time) / 1000000))
    [[ "${VANTAGE_DEBUG_MODULES:-0}" == "1" ]] && echo "DEBUG: Metadata parsed for $module_name (${duration}ms)" >&2
    
    return 0
}

# Function to build complete dependency graph
_build_dependency_graph() {
    local module_path="${1:-$VANTAGE_MODULES_PATH}"
    local start_time=$(date +%s%N 2>/dev/null || date +%s)
    
    echo "Building module dependency graph..." >&2

    VANTAGE_MODULE_DEPS_GRAPH=()
    VANTAGE_MODULE_REVERSE_DEPS=()
    VANTAGE_MODULE_METADATA_CACHE=()
    
    # Find all modules
    local modules=()
    while IFS= read -r module_file; do
        [[ -z "$module_file" ]] && continue
        local module_name=$(basename "$module_file" | sed 's/\.\(module\|sh\)$//')
        modules+=("$module_name:$module_file")
    done < <(find "$module_path" -maxdepth 3 -type f \( -name "*.module" -o -name "*.sh" \) 2>/dev/null | sort)
    
    # Load metadata in the current shell so dependency arrays are populated
    # reliably. Background subshells cannot update the parent shell's maps.
    local load_failed=0
    local restore_errexit=0
    [[ $- == *e* ]] && restore_errexit=1 && set +e
    for module_info in "${modules[@]}"; do
        local module_name="${module_info%%:*}"
        local module_file="${module_info#*:}"

        if ! _load_module_metadata "$module_name" "$module_file" >/dev/null 2>&1; then
            load_failed=1
        fi
    done
    [[ $restore_errexit -eq 1 ]] && set -e

    local end_time=$(date +%s%N 2>/dev/null || date +%s)
    local duration=$((($end_time - $start_time) / 1000000))
    if [[ $load_failed -ne 0 ]]; then
        echo "Dependency graph built with partial metadata in ${duration}ms" >&2
        return 0
    fi
    echo "Dependency graph built in ${duration}ms" >&2
}

# Function to perform topological sort on dependency graph
_topological_sort() {
    local -A in_degree
    local -A visited
    local -a zero_degree
    local -a sorted_order
    
    # Seed every discovered module, including modules without dependencies.
    for module in "${!VANTAGE_MODULE_METADATA_CACHE[@]}"; do
        in_degree["$module"]=0
        visited["$module"]=0
    done
    
    # Count each module's dependencies and ensure dependency nodes exist.
    for module in "${!VANTAGE_MODULE_DEPS_GRAPH[@]}"; do
        local deps="${VANTAGE_MODULE_DEPS_GRAPH[$module]:-}"
        for dep in $deps; do
            if [[ -n "$dep" ]]; then
                [[ -n "${in_degree[$dep]:-}" ]] || in_degree["$dep"]=0
                ((in_degree["$module"]++))
            fi
        done
    done
    
    # Find all modules with no dependencies
    for module in "${!in_degree[@]}"; do
        if [[ "${in_degree[$module]}" -eq 0 ]]; then
            zero_degree+=("$module")
        fi
    done
    if [[ ${#zero_degree[@]} -gt 0 ]]; then
        mapfile -t zero_degree < <(printf '%s\n' "${zero_degree[@]}" | sort)
    fi
    
    # Process modules in topological order
    while [[ ${#zero_degree[@]} -gt 0 ]]; do
        local current="${zero_degree[0]}"
        zero_degree=("${zero_degree[@]:1}")
        sorted_order+=("$current")
        
        # Check modules that depend on current
        local reverse_deps="${VANTAGE_MODULE_REVERSE_DEPS[$current]:-}"
        for dependent in $reverse_deps; do
            ((in_degree["$dependent"]--))
            if [[ "${in_degree[$dependent]}" -eq 0 ]]; then
                zero_degree+=("$dependent")
            fi
        done
        if [[ ${#zero_degree[@]} -gt 1 ]]; then
            mapfile -t zero_degree < <(printf '%s\n' "${zero_degree[@]}" | sort)
        fi
    done
    
    # Return sorted order
    printf '%s\n' "${sorted_order[@]}"
}

# Function to identify independent module groups for parallel loading
_identify_parallel_groups() {
    local -a sorted_modules
    mapfile -t sorted_modules < <(_topological_sort)
    
    local -A module_level
    local max_level=0
    
    # Assign levels based on dependencies
    for module in "${sorted_modules[@]}"; do
        # Skip empty module names
        [[ -z "$module" ]] && continue
        
        local level=0
        local deps="${VANTAGE_MODULE_DEPS_GRAPH[$module]:-}"
        
        for dep in $deps; do
            if [[ -n "$dep" && -n "${module_level[$dep]:-}" ]]; then
                local dep_level="${module_level[$dep]}"
                if (( dep_level >= level )); then
                    level=$((dep_level + 1))
                fi
            fi
        done
        
        module_level["$module"]=$level
        if (( level > max_level )); then
            max_level=$level
        fi
    done
    
    # Group modules by level
    local -a parallel_groups
    for ((i=0; i<=max_level; i++)); do
        local -a group_modules=()
        for module in "${sorted_modules[@]}"; do
            # Skip empty module names
            [[ -z "$module" ]] && continue
            if [[ "${module_level[$module]:-}" -eq $i ]]; then
                group_modules+=("$module")
            fi
        done
        if [[ ${#group_modules[@]} -gt 0 ]]; then
            local group
            group="$(printf '%s ' "${group_modules[@]}")"
            parallel_groups+=("$group")
        fi
    done
    
    # Return groups
    printf '%s\n' "${parallel_groups[@]}"
}

# Function to load a single module with timing
_load_module_with_timing() {
    local module_name="$1"
    local module_file="$2"
    local start_time=$(date +%s%N 2>/dev/null || date +%s)
    
    # Load the module
    if [[ -f "$module_file" ]]; then
        source "$module_file" 2>/dev/null || {
            echo "ERROR: Failed to load module $module_name" >&2
            return 1
        }
        
        # Mark as loaded
        VANTAGE_LOADED_MODULES["$module_name"]=1
        
        local end_time=$(date +%s%N 2>/dev/null || date +%s)
        local duration=$((($end_time - $start_time) / 1000000))
        VANTAGE_MODULE_LOAD_TIMES["$module_name"]=$duration
        
        [[ "${VANTAGE_DEBUG_MODULES:-0}" == "1" ]] && echo "DEBUG: Loaded $module_name in ${duration}ms" >&2
        return 0
    else
        echo "ERROR: Module file not found: $module_file" >&2
        return 1
    fi
}

# Function to load modules in parallel groups
parallel_load_modules() {
    local module_list="${1:-$HOME/.enabled_modules}"
    local start_time=$(date +%s%N 2>/dev/null || date +%s)
    
    if [[ "${VANTAGE_QUIET_MODE:-0}" != "1" && "${VANTAGE_SUPPRESS_MODULE_MESSAGES:-0}" != "1" ]]; then
        echo "=== VANTAGE Parallel Module Loader ===" >&2
    fi
    
    # Build dependency graph
    _build_dependency_graph "$VANTAGE_MODULES_PATH"
    
    # Get modules to load
    local -A modules_to_load
    if [[ -f "$module_list" ]]; then
        while IFS= read -r module_name; do
            [[ -z "$module_name" || "$module_name" =~ ^# ]] && continue
            
            # Skip if already loaded
            if [[ "${VANTAGE_LOADED_MODULES[$module_name]:-}" == "1" ]]; then
                continue
            fi
            
            # Skip lazy modules during startup
            if declare -F is_lazy_load_module &>/dev/null && is_lazy_load_module "$module_name"; then
                local module_file=""
                if [[ -n "${VANTAGE_MODULE_METADATA_CACHE[$module_name]:-}" ]]; then
                    module_file="$(printf '%s\n' "${VANTAGE_MODULE_METADATA_CACHE[$module_name]}" | grep '^FILE:' | cut -d':' -f2-)"
                fi
                if declare -F create_lazy_proxy &>/dev/null; then
                    create_lazy_proxy "$module_name" "$module_file"
                fi
                VANTAGE_LOADED_MODULES["$module_name"]="lazy"
                continue
            fi
            
            modules_to_load["$module_name"]=1
        done < "$module_list"
    fi
    
    # Identify parallel groups
    local -a parallel_groups
    mapfile -t parallel_groups < <(_identify_parallel_groups)
    
    # Add modules without dependencies to the first group
    local orphan_modules=""
    for module_name in "${!modules_to_load[@]}"; do
        local found=0
        for group in "${parallel_groups[@]}"; do
            if [[ " $group " =~ " $module_name " ]]; then
                found=1
                break
            fi
        done
        if [[ $found -eq 0 ]]; then
            orphan_modules="$orphan_modules $module_name"
        fi
    done
    
    # Add orphan modules to groups
    if [[ -n "$orphan_modules" ]]; then
        if [[ ${#parallel_groups[@]} -eq 0 ]]; then
            parallel_groups=("$orphan_modules")
        else
            parallel_groups[0]="${parallel_groups[0]} $orphan_modules"
        fi
    fi
    
    echo "Loading modules in ${#parallel_groups[@]} parallel groups..." >&2
    
    # Load each group
    local total_loaded=0
    for ((i=0; i<${#parallel_groups[@]}; i++)); do
        local group="${parallel_groups[$i]}"
        echo "Loading group $((i+1)): $group" >&2
        
        # Load modules in dependency order within the current shell so the
        # sourced modules can modify the active environment.
        for module_name in $group; do
            if [[ -n "${modules_to_load[$module_name]:-}" ]]; then
                # Get module file from metadata
                local metadata="${VANTAGE_MODULE_METADATA_CACHE[$module_name]:-}"
                local module_file=$(echo "$metadata" | grep "^FILE:" | cut -d':' -f2-)
                
                # If no metadata, try to find the module file directly
                if [[ -z "$module_file" ]]; then
                    if [[ -f "$VANTAGE_MODULES_PATH/${module_name}.module" ]]; then
                        module_file="$VANTAGE_MODULES_PATH/${module_name}.module"
                    elif [[ -f "$VANTAGE_MODULES_PATH/${module_name}.sh" ]]; then
                        module_file="$VANTAGE_MODULES_PATH/${module_name}.sh"
                    fi
                fi
                
                if [[ -n "$module_file" && -f "$module_file" ]]; then
                    if _load_module_with_timing "$module_name" "$module_file" >/dev/null 2>&1; then
                        ((total_loaded++))
                    fi
                fi
            fi
        done
    done
    
    local end_time=$(date +%s%N 2>/dev/null || date +%s)
    local total_duration=$((($end_time - $start_time) / 1000000))
    
    # Print summary
    echo "=== Module Loading Summary ===" >&2
    echo "Total time: ${total_duration}ms" >&2
    echo "Modules loaded: $total_loaded" >&2
    echo "Cache hits: ${#VANTAGE_MODULE_CACHE_HITS[@]}" >&2
    
    # Show slowest modules
    if [[ ${#VANTAGE_MODULE_LOAD_TIMES[@]} -gt 0 ]]; then
        echo "Slowest modules:" >&2
        for module in "${!VANTAGE_MODULE_LOAD_TIMES[@]}"; do
            echo "  $module: ${VANTAGE_MODULE_LOAD_TIMES[$module]}ms"
        done | sort -t':' -k2 -nr | head -5 >&2
    fi
    
    return 0
}

# Function to invalidate cache for a specific module
invalidate_module_cache() {
    local module_name="$1"
    local cache_file="$VANTAGE_MODULE_CACHE_DIR/${module_name}.meta"
    
    if [[ -f "$cache_file" ]]; then
        rm -f "$cache_file"
        echo "Cache invalidated for module: $module_name" >&2
    fi
    
    # Clear from memory cache
    unset "VANTAGE_MODULE_METADATA_CACHE[$module_name]"
    unset "VANTAGE_MODULE_DEPS_GRAPH[$module_name]"
}

# Function to clear all module caches
clear_module_cache() {
    rm -rf "$VANTAGE_MODULE_CACHE_DIR"/*
    
    # Clear memory caches
    unset VANTAGE_MODULE_METADATA_CACHE
    unset VANTAGE_MODULE_DEPS_GRAPH
    unset VANTAGE_MODULE_REVERSE_DEPS
    
    declare -gA VANTAGE_MODULE_METADATA_CACHE
    declare -gA VANTAGE_MODULE_DEPS_GRAPH
    declare -gA VANTAGE_MODULE_REVERSE_DEPS
    
    echo "All module caches cleared" >&2
}

# Function to show module dependency graph
show_module_dependencies() {
    local module_name="$1"
    
    if [[ -z "$module_name" ]]; then
        # Show all dependencies
        echo "=== Module Dependency Graph ===" >&2
        for module in "${!VANTAGE_MODULE_DEPS_GRAPH[@]}"; do
            local deps="${VANTAGE_MODULE_DEPS_GRAPH[$module]}"
            if [[ -n "$deps" ]]; then
                echo "$module -> $deps" >&2
            else
                echo "$module (no dependencies)" >&2
            fi
        done
    else
        # Show dependencies for specific module
        local deps="${VANTAGE_MODULE_DEPS_GRAPH[$module_name]}"
        local reverse_deps="${VANTAGE_MODULE_REVERSE_DEPS[$module_name]}"
        
        echo "=== Dependencies for $module_name ===" >&2
        echo "Depends on: ${deps:-none}" >&2
        echo "Required by: ${reverse_deps:-none}" >&2
    fi
}

# Export functions for use by module system
export -f parallel_load_modules
export -f invalidate_module_cache
export -f clear_module_cache
export -f show_module_dependencies

# Alias for convenience
alias modules-parallel='parallel_load_modules'
alias modules-cache-clear='clear_module_cache'
alias modules-deps='show_module_dependencies'

if [[ "${VANTAGE_QUIET_MODE:-0}" != "1" && "${VANTAGE_SUPPRESS_MODULE_MESSAGES:-0}" != "1" ]]; then
    echo "VANTAGE Parallel Module Loader initialized" >&2
fi
