#!/usr/bin/env bash
# VANTAGE Context Module
# Provides integration between command learning and chat systems

# Prevent multiple loading
[[ -n "${_VANTAGE_CONTEXT_LOADED}" ]] && return 0
export _VANTAGE_CONTEXT_LOADED=1

# Check if Python is available
if ! command -v python3 &>/dev/null; then
    echo "Warning: Python 3 not found. VANTAGE context features disabled."
    return 0
fi

# Path to context script
VANTAGE_CTX_DIR="$(dirname "${BASH_SOURCE[0]}")/../contrib"
VANTAGE_CTX_SCRIPT="$VANTAGE_CTX_DIR/vantage_context.py"

# Make sure the context script exists
if [ ! -f "$VANTAGE_CTX_SCRIPT" ]; then
    echo "Error: vantage_context.py not found at $VANTAGE_CTX_SCRIPT"
    return 0
fi

# Record successful commands to context
function __vantage_record_command() {
    local exit_code=$1
    local command="$2"
    
    # Only record successful, non-empty commands
    if [ $exit_code -eq 0 ] && [ -n "$command" ]; then
        # Don't record commands with sensitive keywords
        if ! echo "$command" | grep -q -i "password\|secret\|key\|token\|credential"; then
            # Run context update in background to avoid slowing down the shell
            # Use disown to completely detach the process and prevent job notifications
            # Run in a clean subshell with no verbosity
            ( 
                set +x +v 2>/dev/null
                ( python3 "$VANTAGE_CTX_SCRIPT" --record "$command" --exit-code $exit_code >/dev/null 2>&1 & ) 2>/dev/null 
                disown 
            ) >/dev/null 2>&1
        fi
    fi
}

# Hook into command completion
function __vantage_command_done() {
    local exit_code=$?
    local last_cmd=$(HISTTIMEFORMAT= history 1 | sed 's/^[ 0-9]\+[ ]\+//')
    
    # Temporarily disable job control to prevent notifications
    local old_opts=$(set +o | grep monitor)
    set +m 2>/dev/null
    
    __vantage_record_command $exit_code "$last_cmd"
    
    # Restore job control setting
    eval "$old_opts" 2>/dev/null
    
    return $exit_code
}

# Add our function to PROMPT_COMMAND to run after each command
# Use trap DEBUG to capture the command before execution
if [[ "$PROMPT_COMMAND" != *"__vantage_command_done"* ]]; then
    PROMPT_COMMAND="__vantage_command_done;${PROMPT_COMMAND:-:}"
fi

# Analyze and record sequences of commands
function __vantage_analyze_sequence() {
    local count=${1:-5}
    # Get last N commands from history
    local cmds=$(HISTTIMEFORMAT= history $count | sed 's/^[ 0-9]\+[ ]\+//')
    
    # Convert to comma-separated list for the context script
    local cmd_list=$(echo "$cmds" | tr '\n' ',' | sed 's/,$//')
    
    # Add sequence to context
    ( python3 "$VANTAGE_CTX_SCRIPT" --add-sequence "$cmd_list" >/dev/null 2>&1 & disown ) 2>/dev/null
}

# Function to update context manually
function vantage_update_context() {
    python3 "$VANTAGE_CTX_SCRIPT" --update
    echo "VANTAGE context updated"
}

# Function to show current context
function vantage_show_context() {
    python3 "$VANTAGE_CTX_SCRIPT" --get | jq . 2>/dev/null || 
        python3 "$VANTAGE_CTX_SCRIPT" --get
}

# Function to get context formatted for humans
function vantage_context() {
    python3 "$VANTAGE_CTX_SCRIPT" --for-llm
}

# Function to suggest commands based on context
function vantage_smart_suggest() {
    local prefix="$1"
    if [ -z "$prefix" ]; then
        echo "Usage: vantage_smart_suggest <command_prefix>"
        return 0
    fi
    
    # Get suggestions based on prefix
    python3 "$VANTAGE_CTX_SCRIPT" --suggest "$prefix" | 
        jq -r '.[] | "\(.confidence*100 | floor)% \(.command) - \(.description)"' 2>/dev/null ||
        python3 "$VANTAGE_CTX_SCRIPT" --suggest "$prefix"
}

# Integrate with other VANTAGE modules if they exist
if declare -F module_enable >/dev/null; then
    # Check if vantage_ml is loaded
    if [[ "${VANTAGE_LOADED_MODULES[vantage_ml]}" == "1" ]]; then
        echo "Integrating context with vantage_ml module..."
        
        # Periodically analyze command sequences when using vantage_ml
        # This will run sequence analysis every 20 commands
        if [ -n "$VANTAGE_ML_ENABLED" ] && [ "$VANTAGE_ML_ENABLED" -eq 1 ]; then
            function __vantage_periodic_sequence_analysis() {
                # Run sequence analysis every ~20 commands (based on hash)
                local cmd="$1"
                local hash=$(($(echo "$cmd" | cksum | cut -d' ' -f1) % 20))
                if [ "$hash" -eq 0 ]; then
                    __vantage_analyze_sequence 5
                fi
            }
            
            # Hook into the existing PROMPT_COMMAND
            if [[ "$PROMPT_COMMAND" != *"__vantage_periodic_sequence_analysis"* ]]; then
                PROMPT_COMMAND="__vantage_periodic_sequence_analysis \$(HISTTIMEFORMAT= history 1 | sed 's/^[ 0-9]\\+[ ]\\+//');${PROMPT_COMMAND:-:}"
            fi
        fi
    fi
    
    # Check if vantage_chat is loaded
    if [[ "${VANTAGE_LOADED_MODULES[vantage_chat]}" == "1" ]]; then
        echo "Integrating context with vantage_chat module..."
        
        # Export context for chat
        export VANTAGE_CONTEXT_AVAILABLE=1
    fi
fi

# Create bash completion for vantage context commands
complete -F "__vantage_completion" vantage_smart_suggest

function __vantage_completion() {
    local cur=${COMP_WORDS[COMP_CWORD]}
    if [ ${#cur} -ge 1 ]; then
        local suggestions=$(python3 "$VANTAGE_CTX_SCRIPT" --suggest "$cur" | 
                          jq -r '.[].command' 2>/dev/null)
        
        if [ -n "$suggestions" ]; then
            COMPREPLY=( $(compgen -W "$suggestions" -- "$cur") )
        fi
    fi
}

# Command aliases
alias ctx="vantage_context"
alias ctxshow="vantage_show_context"
alias ctxupdate="vantage_update_context"
alias suggest="vantage_smart_suggest"

# Initial context update on module load
( vantage_update_context >/dev/null 2>&1 & disown ) 2>/dev/null

if [[ "${VANTAGE_QUIET_MODE:-0}" != "1" && "${VANTAGE_SUPPRESS_MODULE_MESSAGES:-0}" != "1" ]]; then
    echo "VANTAGE Context module loaded"
fi 